# Shared monorepo configuration

# Database and auth
POSTGRES_USER=aop_builder
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_DB=aop_builder
DATABASE_URL=postgresql://aop_builder:replace-with-local-postgres-password@postgres_db:5432/aop_builder
SECRET_KEY=replace-with-random-32-byte-secret
ALGORITHM=HS256

# Frontend
VITE_API_URL=
PUBLIC_GATEWAY_PORT=8005

# Deployment images
IMAGE_REGISTRY=ghcr.io/aoptimisten
IMAGE_TAG=latest

# Local LLM configuration
LLM_OLLAMA_MODEL=qwen3:14b
RELEVANCE_PROVIDER=local_tfidf
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
CER_API_BASE_URL=http://llm_service:11434/v1
CER_API_KEY=ollama
CER_MODEL_DEFAULT=qwen3:14b
CER_MODEL_QWEN3_14B=qwen3:14b
CER_MODEL_DEEPSEEK_R1_14B=deepseek-r1:14b
CER_MODEL_QWEN3_8B=qwen3:8b
CER_MAX_CONCURRENT_SESSIONS=auto
CER_CONCURRENCY_HEADROOM_FACTOR=1.2
CER_CONCURRENCY_MAX_CAP=4
OLS_BASE_URL=https://www.ebi.ac.uk/ols4/api
OLS_SEARCH_ROWS=5
AOP_MCP_BASE_URL=
AOP_MCP_SEARCH_TOOLS=search_aops,map_chemical_to_aops,get_aop,list_key_events,list_kers,search_key_events,find_key_events,get_key_event
ENRICHMENT_REQUEST_TIMEOUT_SECONDS=20
AOP_MCP_IMAGE=docker-stack-aop-mcp:latest
AOP_MCP_LOG_LEVEL=INFO
AOP_MCP_ENABLE_FIXTURE_FALLBACK=1

# Optional cloud provider keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=
